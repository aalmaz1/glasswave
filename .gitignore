```
# Dependencies
.dart_tool/
.packages
.pub/
pubspec.lock

# Logs and temp files
*.log
*.tmp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Build outputs
build/
dist/
target/

# Python artifacts (if any Python files exist in project)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Node artifacts (if any JS/TS files exist in project)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage directory used by tools like Istanbul
coverage/
*.lcov

# Temporary folders
tmp/
temp/
```